# ============================================
# HIPARE - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ============================================

# --- API Keys (at least one is required) ---

# Groq API key - get from https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API key - get from https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenRouter API key - get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# --- Server Configuration ---

# Port for the Hipare web server (default: 3002)
PORT=3002

# --- Optional Configuration ---

# Path to REAPER installation (auto-detected if not set)
# REAPER_PATH=C:\Users\YourName\AppData\Roaming\REAPER

# Python executable path (default: python)
# PYTHON_PATH=python

# MCP profile to use (default: dsl-production)
# MCP_PROFILE=dsl-production

# Request timeout in milliseconds (default: 15000)
# REQUEST_TIMEOUT=15000

# --- Reaper Bridge Configuration ---

# Host for the Python bridge server (default: 127.0.0.1)
# REAPER_BRIDGE_HOST=127.0.0.1

# Port for the Python bridge server (default: 3003)
# REAPER_BRIDGE_PORT=3003
